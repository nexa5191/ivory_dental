// Ivory Dental Suite — database schema.
//
// Models the full mock domain currently held in lib/*.ts (in-memory singletons):
//   • Clinic      — providers, patients, dental charts, appointments,
//                   prescriptions, visits, invoices, payments, locations, leave
//   • Inventory   — suppliers, products, per-location stock, movements, orders
//   • Procurement — vendors, GST registrations, RFQs, quotes, purchase orders,
//                   goods receipts, invites
//   • Tax/GST     — compliance ledger + audit trail, GSTR-1 locks, electronic
//                   cash & credit ledgers, RCM inward supplies, job-work challans
//
// MONEY CONVENTION (carried over from the app): all amounts are stored in USD
// base and converted at display time. Stored as Float to mirror the JS numbers
// the app uses today; switch to Decimal if exact currency math is later needed.

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum Gender {
  M
  F
  Other
}

enum ApptType {
  IN_CLINIC @map("in-clinic")
  VIDEO     @map("video")
  PHONE     @map("phone")
}

enum ApptStatus {
  BOOKED     @map("booked")
  ARRIVED    @map("arrived")
  IN_CONSULT @map("in-consult")
  COMPLETED  @map("completed")
  NO_SHOW    @map("no-show")
}

enum ToothStatus {
  HEALTHY @map("healthy")
  CARIES  @map("caries")
  FILLED  @map("filled")
  CROWN   @map("crown")
  RCT     @map("rct")
  MISSING @map("missing")
  IMPLANT @map("implant")
}

enum TreatmentStatus {
  PLANNED     @map("planned")
  IN_PROGRESS @map("in-progress")
  DONE        @map("done")
}

enum InvoiceStatus {
  PAID    @map("paid")
  DUE     @map("due")
  PARTIAL @map("partial")
}

enum PayMode {
  CASH   @map("cash")
  CARD   @map("card")
  UPI    @map("upi")
  ONLINE @map("online")
}

enum MovementType {
  IN       @map("in")
  OUT      @map("out")
  TRANSFER @map("transfer")
  WRITEOFF @map("writeoff")
}

enum OrderType {
  PURCHASE @map("purchase")
  SALES    @map("sales")
}

enum OrderStatus {
  DRAFT     @map("draft")
  OPEN      @map("open")
  SHIPPED   @map("shipped")
  RECEIVED  @map("received")
  CANCELLED @map("cancelled")
}

enum VendorCategory {
  CONSUMABLES     @map("Consumables")
  EQUIPMENT       @map("Equipment")
  INSTRUMENTS     @map("Instruments")
  LAB_SERVICES    @map("Lab Services")
  PHARMACY        @map("Pharmacy")
  OFFICE_SUPPLIES @map("Office Supplies")
}

enum Channel {
  EMAIL @map("email")
  SMS   @map("sms")
  BOTH  @map("both")
}

enum RfqStatus {
  DRAFT   @map("draft")
  SENT    @map("sent")
  QUOTED  @map("quoted")
  AWARDED @map("awarded")
}

enum POStatus {
  ISSUED   @map("issued")
  PARTIAL  @map("partial")
  RECEIVED @map("received")
  INVOICED @map("invoiced")
  PAID     @map("paid")
  CLOSED   @map("closed")
}

enum POPayMode {
  BANK   @map("bank")
  UPI    @map("upi")
  CARD   @map("card")
  CHEQUE @map("cheque")
  CASH   @map("cash")
}

enum CashEntryKind {
  DEPOSIT    @map("deposit")
  SETTLEMENT @map("settlement")
}

enum CreditEntryKind {
  ACCRUAL     @map("accrual")
  UTILISATION @map("utilisation")
}

enum JobWorkStatus {
  SENT     @map("sent")
  RECEIVED @map("received")
}

enum TenantPlan {
  TRIAL @map("trial")
  BASIC @map("basic")
  PRO   @map("pro")
}

enum TenantStatus {
  ACTIVE    @map("active")
  SUSPENDED @map("suspended")
  CHURNED   @map("churned")
}

// Shared by TenantInvite, StaffInvite, and VendorInvite
enum InviteTokenStatus {
  PENDING  @map("pending")
  ACCEPTED @map("accepted")
  EXPIRED  @map("expired")
  REVOKED  @map("revoked")
}


// One row per dental clinic/chain that signs up.
model Tenant {
  id          String       @id @default(cuid())
  name        String       // clinic display name
  slug        String       @unique // URL-safe identifier, e.g. "ivory-dental-bkc"
  plan        TenantPlan   @default(TRIAL)
  status      TenantStatus @default(ACTIVE)
  trialEndsAt String?      // ISO date
  createdAt   String       // ISO

  // Relations — every major domain model hangs off Tenant
  locations         Location[]
  providers         Provider[]
  patients          Patient[]
  appointments      Appointment[]
  prescriptions     Prescription[]
  visits            Visit[]
  invoices          Invoice[]
  suppliers         Supplier[]
  products          Product[]
  orders            Order[]
  vendors           Vendor[]
  vendorInvites     VendorInvite[]
  rfqs              Rfq[]
  purchaseOrders    PurchaseOrder[]
  complianceRecords ComplianceRecord[]
  gstr1Filings      Gstr1Filing[]
  cashEntries       CashLedgerEntry[]
  filedReturns      FiledReturn3B[]
  creditEntries     CreditLedgerEntry[]
  rcmSupplies       RcmInwardSupply[]
  jobWorkChallans   JobWorkChallan[]
  users             User[]
  roles             Role[]
  staffInvites      StaffInvite[]
  invite            TenantInvite?
}

// Superadmin sends this to a clinic owner to begin onboarding.
// The tenant row is created *during* the owner's onboarding, not before.
model TenantInvite {
  token     String            @id // e.g. tinv-xxxxxxxxxxxxxxxx
  email     String
  sentBy    String            // superadmin identifier (email or id)
  sentAt    String
  expiresAt String
  status    InviteTokenStatus @default(PENDING)

  // Set once the invited owner completes onboarding and the tenant is created
  tenantId  String?           @unique
  tenant    Tenant?           @relation(fields: [tenantId], references: [id])
}

// Tenant admin invites staff (receptionist, junior dentist, etc.)
model StaffInvite {
  token     String            @id // e.g. sinv-xxxxxxxxxxxxxxxx
  tenantId  String
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email     String
  roleId    Int               // role pre-assigned by the inviting admin
  role      Role              @relation(fields: [roleId], references: [id])
  invitedBy Int               // userId of the admin who sent this
  inviter   User              @relation("SentInvites", fields: [invitedBy], references: [id])
  sentAt    String
  expiresAt String
  status    InviteTokenStatus @default(PENDING)

  @@index([tenantId])
}

// Login identity for all staff (clinical + non-clinical).
// A User who is also a treating dentist links to a Provider row.
model User {
  id           Int       @id @default(autoincrement())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  email        String
  passwordHash String
  isActive     Boolean   @default(true)
  lastLoginAt  String?
  createdAt    String

  // Optional clinical link — null for receptionists, data-entry staff, etc.
  providerId   Int?      @unique
  provider     Provider? @relation(fields: [providerId], references: [id])

  roles        UserRole[]
  sentInvites  StaffInvite[] @relation("SentInvites")

  @@unique([tenantId, email]) // email unique per tenant, not globally
  @@index([tenantId])
}

// A role belongs to one tenant (or to no tenant when isSystem = true).
// System roles: SUPER_ADMIN, ADMIN, SUPPORT — seeded at deploy time, undeletable.
// Tenant roles: anything the clinic creates, e.g. "Data Entry Operator".
model Role {
  id          Int      @id @default(autoincrement())
  tenantId    String?  // null = system role
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String   // e.g. "Admin", "Data Entry Operator"
  description String?
  isSystem    Boolean  @default(false) // system roles cannot be edited or deleted

  permissions  Permission[]
  userRoles    UserRole[]
  staffInvites StaffInvite[]

  @@unique([tenantId, name]) // name unique within a tenant (nulls treated as distinct by Postgres)
  @@index([tenantId])
}

// A single capability string granted to a role.
// Convention:  resource:action   → "patients:read", "invoices:write"
//              ui:feature        → "ui:bulk_upload", "ui:export_csv"
//              module:access     → "procurement:access", "gst:access"
// The app checks: user.permissions.includes('patients:read')
model Permission {
  id         Int    @id @default(autoincrement())
  roleId     Int
  role       Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission String // the capability string

  @@unique([roleId, permission])
  @@index([roleId])
}

// Junction: which roles a user currently holds (a user may hold multiple).
model UserRole {
  id       Int    @id @default(autoincrement())
  userId   Int
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId   Int
  role     Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Clinic — locations, providers, patients & the clinical record
// ─────────────────────────────────────────────────────────────────────────────

model Location {
  id        Int     @id @default(autoincrement())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  address   String
  city      String
  phone     String
  email     String
  gstin     String
  lead      String
  chairs    Int     @default(1)
  openHours String
  active    Boolean @default(true)

  patients Patient[]

  @@index([tenantId])
}

model Provider {
  id        Int    @id @default(autoincrement())
  tenantId  String
  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  specialty String
  reg       String
  color     String

  appointments  Appointment[]
  prescriptions Prescription[]
  visits        Visit[]
  timeOff       TimeOff[]
  user          User?

  @@index([tenantId])
}

model Patient {
  id          Int      @id @default(autoincrement())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  dob         String
  anniversary String?
  gender      Gender   @default(Other)
  phone       String
  email       String
  bloodGroup  String
  abhaId      String?
  gstin       String?
  allergies   String[]
  conditions  String[]
  balance     Float    @default(0)
  lastVisit   String

  locationId Int?
  location   Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  toothFindings ToothFinding[]
  treatmentPlan TreatmentItem[]
  xrays         XrayImage[]
  appointments  Appointment[]
  prescriptions Prescription[]
  visits        Visit[]
  invoices      Invoice[]

  @@index([tenantId])
  @@index([locationId])
}


// Per-tooth chart finding (FDI numbering). Replaces Patient.toothFindings map.
model ToothFinding {
  id        Int         @id @default(autoincrement())
  patientId Int
  patient   Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  tooth     Int // FDI number
  status    ToothStatus

  @@unique([patientId, tooth])
}

model TreatmentItem {
  id        Int             @id @default(autoincrement())
  patientId Int
  patient   Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  tooth     Int? // null = not tooth-specific
  procedure String
  phase     Int             @default(1)
  estimate  Float // USD
  status    TreatmentStatus @default(PLANNED)
  billed    Boolean         @default(false) // hidden from the chart once invoiced

  @@index([patientId])
}

model XrayImage {
  id        Int     @id @default(autoincrement())
  patientId Int
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  name      String
  dataUrl   String // base64 data URL (no real blob storage in the mock)
  date      String
  tooth     Int?
  note      String?

  @@index([patientId])
}

model Appointment {
  id          Int        @id @default(autoincrement())
  tenantId    String
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patientId   Int
  patient     Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  providerId  Int
  provider    Provider   @relation(fields: [providerId], references: [id])
  start       String
  durationMin Int        @default(30)
  type        ApptType   @default(IN_CLINIC)
  status      ApptStatus @default(BOOKED)
  reason      String
  chair       String

  @@index([tenantId])
  @@index([patientId])
  @@index([providerId])
}

model Prescription {
  id             Int      @id @default(autoincrement())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patientId      Int
  patient        Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  providerId     Int
  provider       Provider @relation(fields: [providerId], references: [id])
  date           String
  advice         String[]
  patientName    String?
  prescriberName String?
  signName       String?

  items    PrescriptionItem[]
  invoices Invoice[]

  @@index([tenantId])
  @@index([patientId])
  @@index([providerId])
}

model PrescriptionItem {
  id             Int          @id @default(autoincrement())
  prescriptionId Int
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  drug           String
  dosage         String
  frequency      String
  duration       String
  notes          String?

  @@index([prescriptionId])
}

model Visit {
  id         Int      @id @default(autoincrement())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patientId  Int
  patient    Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  providerId Int
  provider   Provider @relation(fields: [providerId], references: [id])
  date       String
  complaint  String
  notes      String

  @@index([tenantId])
  @@index([patientId])
  @@index([providerId])
}

model Invoice {
  id        Int           @id @default(autoincrement())
  tenantId  String
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patientId Int
  patient   Patient       @relation(fields: [patientId], references: [id])
  date      String
  total     Float
  status    InvoiceStatus @default(DUE)
  mode      PayMode       @default(CASH)
  rxId      Int?
  rx        Prescription? @relation(fields: [rxId], references: [id])

  items    InvoiceItem[]
  payments Payment[]

  @@index([tenantId])
  @@index([patientId])
  @@index([rxId])
}

model InvoiceItem {
  id        Int     @id @default(autoincrement())
  invoiceId Int
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  desc      String
  amount    Float // USD

  @@index([invoiceId])
}

model Payment {
  id        Int     @id @default(autoincrement())
  invoiceId Int
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount    Float // USD
  mode      PayMode
  reference String?
  date      String

  @@index([invoiceId])
}

// Doctor leave / calendar block. Whole-day unless startTime/endTime are set.
model TimeOff {
  id         Int      @id @default(autoincrement())
  providerId Int
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  from       String // YYYY-MM-DD, inclusive
  to         String // YYYY-MM-DD, inclusive
  reason     String
  startTime  String? // HH:MM — partial-day block
  endTime    String?

  @@index([providerId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Inventory — suppliers, products, stock, movements, orders
// ─────────────────────────────────────────────────────────────────────────────

model Supplier {
  id           Int       @id @default(autoincrement())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  contact      String
  email        String
  leadTimeDays Int
  rating       Int

  products Product[]

  @@index([tenantId])
}

model Product {
  id           Int      @id @default(autoincrement())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  sku          String
  category     String
  stock        Int      @default(0)
  reorderPoint Int      @default(10)
  cost         Float
  price        Float
  location     String

  supplierId Int
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  stockByLocation ProductStock[]
  movements       Movement[]
  orderLines      OrderLine[]

  @@index([tenantId])
  @@index([supplierId])
}

// Quantity of a product held at one warehouse/location.
model ProductStock {
  id        Int     @id @default(autoincrement())
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  location  String // warehouse name
  qty       Int     @default(0)

  @@unique([productId, location])
}

model Movement {
  id        Int          @id @default(autoincrement())
  productId Int
  product   Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      MovementType
  qty       Int
  ref       String
  date      String // ISO

  @@index([productId])
}

// Purchase or sales order from the inventory module (distinct from procurement
// PurchaseOrder, which is the vendor-portal flow).
model Order {
  id       Int         @id @default(autoincrement())
  tenantId String
  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type     OrderType
  partyId  String
  party    String
  status   OrderStatus
  total    Float
  date     String

  lines OrderLine[]

  @@index([tenantId])
}

model OrderLine {
  id        Int     @id @default(autoincrement())
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  qty       Int
  unitPrice Float

  @@index([orderId])
  @@index([productId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Procurement — vendors, RFQs, quotes, purchase orders, goods receipts
// ─────────────────────────────────────────────────────────────────────────────

model Vendor {
  id       Int            @id @default(autoincrement())
  tenantId String
  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name     String
  category VendorCategory @default(CONSUMABLES)
  contact  String
  email    String
  phone    String
  city     String
  gstin    String
  pan      String?
  rating   Int            @default(4)
  active   Boolean        @default(true)
  msme     Boolean        @default(false)
  udyam    String?
  token    String         @unique

  bankAccountName   String?
  bankAccountNumber String?
  bankIfsc          String?
  bankName          String?
  bankBranch        String?

  tdsSection String?
  tdsRate    Float?

  registrations  GstRegistration[]
  quotes         Quote[]
  purchaseOrders PurchaseOrder[]
  invitedToRfqs  Rfq[]             @relation("RfqInvitedVendors")
  awards         RfqAward[]
  invite         VendorInvite?

  @@index([tenantId])
}

// One GST registration held by a vendor (a party may hold several — one per state).
model GstRegistration {
  id             Int     @id @default(autoincrement())
  vendorId       Int
  vendor         Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  gstin          String
  pan            String
  tradeName      String
  legalName      String?
  label          String // e.g. "Head Office", "Mumbai depot"
  stateCode      String
  address1       String
  address2       String
  city           String
  state          String
  pincode        String
  primary        Boolean @default(false)
  taxpayerType   String? // Regular / SEZ Unit / ISD / Composition
  taxpayerStatus String? // Active / Cancelled

  @@index([vendorId])
}

// Self-registration invite — a prospective vendor opens the link & registers.
model VendorInvite {
  token     String            @id // e.g. vreg-xxxxxxxx
  tenantId  String
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email     String?
  phone     String?
  note      String?
  createdAt String
  status    InviteTokenStatus @default(PENDING)
  vendorId  Int?              @unique
  vendor    Vendor?           @relation(fields: [vendorId], references: [id])

  @@index([tenantId])
}

model Rfq {
  id              Int            @id @default(autoincrement())
  tenantId        String
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title           String
  category        VendorCategory
  createdAt       String
  status          RfqStatus      @default(DRAFT)
  channel         Channel        @default(EMAIL)
  notes           String?
  awardedVendorId Int?
  poId            Int?

  items          RfqItem[]
  quotes         Quote[]
  awards         RfqAward[]
  invitedVendors Vendor[]   @relation("RfqInvitedVendors")

  @@index([tenantId])
}

model RfqItem {
  id    Int    @id @default(autoincrement())
  rfqId Int
  rfq   Rfq    @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  name  String
  qty   Float
  unit  String

  @@index([rfqId])
}

model Quote {
  id           Int         @id @default(autoincrement())
  rfqId        Int
  rfq          Rfq         @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  vendorId     Int
  vendor       Vendor      @relation(fields: [vendorId], references: [id])
  submittedAt  String
  total        Float // USD
  leadTimeDays Int
  validityDays Int
  notes        String?

  lines QuoteLine[]

  @@index([rfqId])
  @@index([vendorId])
}

model QuoteLine {
  id        Int    @id @default(autoincrement())
  quoteId   Int
  quote     Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  itemName  String
  qty       Float
  unitPrice Float // USD

  @@index([quoteId])
}

// A split/partial award row: which vendor won, and the PO it produced.
model RfqAward {
  id       Int           @id @default(autoincrement())
  rfqId    Int
  rfq      Rfq           @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  vendorId Int
  vendor   Vendor        @relation(fields: [vendorId], references: [id])
  poId     Int
  po       PurchaseOrder @relation(fields: [poId], references: [id])

  @@index([rfqId])
  @@index([vendorId])
}

model PurchaseOrder {
  id       Int      @id @default(autoincrement())
  tenantId String
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rfqId    Int?
  rfqTitle String
  vendorId Int
  vendor   Vendor   @relation(fields: [vendorId], references: [id])
  date     String
  total    Float
  status   POStatus @default(ISSUED)
  manual   Boolean  @default(false)

  invoiceNumber String?
  invoiceDate   String?
  invoiceAmount Float?

  paymentDate      String?
  paymentMode      POPayMode?
  paymentReference String?
  paymentAmount    Float?

  closedReason String?

  items    POItem[]
  receipts GoodsReceipt[]
  awards   RfqAward[]

  @@index([tenantId])
  @@index([vendorId])
  @@index([rfqId])
}

// Ordered line on a purchase order (mirrors a QuoteLine).
model POItem {
  id        Int           @id @default(autoincrement())
  poId      Int
  po        PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  itemName  String
  qty       Float
  unitPrice Float // USD

  @@index([poId])
}

// Goods Receipt Note — one delivery event against a PO (a PO may have several).
model GoodsReceipt {
  id    Int                @id @default(autoincrement())
  poId  Int
  po    PurchaseOrder      @relation(fields: [poId], references: [id], onDelete: Cascade)
  date  String
  note  String?
  lines GoodsReceiptLine[]

  @@index([poId])
}

model GoodsReceiptLine {
  id        Int          @id @default(autoincrement())
  receiptId Int
  receipt   GoodsReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  itemName  String
  qty       Float // billable units (count toward the ordered balance)
  free      Float        @default(0) // bonus units — stocked but not billed

  @@index([receiptId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Tax / GST — compliance ledger, period locks, cash & credit ledgers, RCM, ITC-04
// ─────────────────────────────────────────────────────────────────────────────

// Per-document compliance state. docKey is the polymorphic document identifier
// used by the app (e.g. "INV-2001", "PO-1001", "tdsp:PO-1003"). It is not a
// foreign key — cross-tenant validity must be enforced at the application layer.
model ComplianceRecord {
  id           Int     @id @default(autoincrement())
  tenantId     String
  tenant       Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  docKey       String  // polymorphic document reference (app-layer FK only)
  gstr1Filed   Boolean @default(false)
  gstr1Ref     String?
  gstr1Period  String?
  gstr1Held    Boolean @default(false)
  itcClaimed   Boolean @default(false)
  itcRef       String?
  itcPeriod    String?
  itcHeld      Boolean @default(false)
  tdsDeposited Boolean @default(false)
  challanNo    String?
  tdsCertified Boolean @default(false)
  certNo       String?

  trail ComplianceTrailEvent[]

  @@unique([tenantId, docKey])
  @@index([tenantId])
}

model ComplianceTrailEvent {
  id       Int              @id @default(autoincrement())
  recordId Int
  record   ComplianceRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  ts       String
  event    String
  ref      String?

  @@index([recordId])
}

// Period-level GSTR-1 filing & lock.
model Gstr1Filing {
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  period   String
  date     String

  @@id([tenantId, period])
}

// Electronic Cash Ledger entry (signed per head: deposits +, settlements −).
model CashLedgerEntry {
  id       Int           @id @default(autoincrement())
  tenantId String
  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  date     String
  kind     CashEntryKind
  ref      String?
  period   String?
  igst     Float         @default(0)
  cgst     Float         @default(0)
  sgst     Float         @default(0)

  @@index([tenantId])
}

// A filed & locked GSTR-3B return (cash paid per head for the period).
model FiledReturn3B {
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  period   String
  igst     Float
  cgst     Float
  sgst     Float
  date     String

  @@id([tenantId, period])
}

// Electronic Credit (ITC) Ledger entry (signed: accrual +, utilisation −).
model CreditLedgerEntry {
  id       Int             @id @default(autoincrement())
  tenantId String
  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  date     String
  kind     CreditEntryKind
  ref      String?
  period   String?
  igst     Float           @default(0)
  cgst     Float           @default(0)
  sgst     Float           @default(0)

  @@index([tenantId])
}

// Reverse-charge (RCM) inward supply — the clinic self-pays GST.
model RcmInwardSupply {
  id         Int     @id @default(autoincrement())
  tenantId   String
  tenant     Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  date       String
  period     String
  fy         String
  supplier   String
  desc       String
  code       String
  rate       Float
  taxable    Float
  cgst       Float   @default(0)
  sgst       Float   @default(0)
  igst       Float   @default(0)
  tax        Float
  interState Boolean @default(false)

  @@index([tenantId])
}

// ITC-04 job-work challan — materials sent to / prosthetics received from a lab.
model JobWorkChallan {
  challanNo    String        @id
  tenantId     String
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  date         String
  period       String
  fy           String
  jobWorker    String
  itemSent     String
  qtySent      Float
  itemReceived String
  qtyReceived  Float
  status       JobWorkStatus
  taxableValue Float

  @@index([tenantId])
}
